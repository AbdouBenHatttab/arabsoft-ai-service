# .env.example
# Copy this file to .env and fill in values for your environment.
# All EXTERNAL_AGENT_* settings default to safe values — leave them as-is
# for local development and testing (no provider calls will be made).

# ---------------------------------------------------------------------------
# External agentic AI provider
# ---------------------------------------------------------------------------

# Set to true only when you have a real provider configured below.
EXTERNAL_AGENT_ENABLED=false

# Base URL of the external AI provider (no trailing slash).
EXTERNAL_AGENT_BASE_URL=https://your-provider.example.com

# API key for the external AI provider. Keep this secret — never commit it.
EXTERNAL_AGENT_API_KEY=

# Model name/identifier passed to the provider.
EXTERNAL_AGENT_MODEL=

# HTTP timeout in seconds for provider calls.
EXTERNAL_AGENT_TIMEOUT_SECONDS=8

# ---------------------------------------------------------------------------
# Google Gemini (Phase 2 — Platform Q&A)
# ---------------------------------------------------------------------------

# Set to true to enable Gemini for unanswered platform questions.
GEMINI_ENABLED=false

# Your Google AI Studio API key. Keep this secret — never commit it.
GEMINI_API_KEY=

# Gemini model to use. gemini-2.5-flash is fast and capable for Q&A.
GEMINI_MODEL=gemini-2.5-flash

# HTTP timeout in seconds for Gemini calls.
GEMINI_TIMEOUT_SECONDS=10
